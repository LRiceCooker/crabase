{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-config-schema/schema.json",
  "productName": "crabase",
  "version": "0.1.0",
  "identifier": "com.crabase.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:8080",
    "beforeDevCommand": "trunk serve --port 8080",
    "beforeBuildCommand": "trunk build"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "crabase",
        "width": 1200,
        "height": 800,
        "backgroundColor": "#0A0A0A"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["dmg", "app"],
    "icon": [
      "icons/icon.icns",
      "icons/icon.ico",
      "icons/icon.png",
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png"
    ],
    "category": "DeveloperTool",
    "shortDescription": "A minimal PostgreSQL desktop client",
    "longDescription": "crabase is a beautiful, minimal PostgreSQL desktop client built with Rust. Connect to databases, explore schemas and tables, edit data inline, run SQL queries, and restore backups.",
    "macOS": {
      "minimumSystemVersion": "10.15",
      "signingIdentity": "Developer ID Application: MATHYS DUPONT (S8ST96C2KG)"
    },
    "resources": [
      "icons/light/icon.png",
      "icons/dark/icon.png"
    ]
  }
}
